# ── Speaker Verification (Voice Enrollment) ────────────────────────────────
# Set to 1 to enable — Vani will only respond to the enrolled owner's voice.
# RECOMMENDED: set to 1 after enrolling.  Without this, anyone who says
# "Vani" in the room will trigger her.  Default: 0 (disabled).
VANI_SPEAKER_VERIFY=1

# Cosine similarity threshold. Higher = stricter. Range: 0.0–1.0. Default: 0.75
# 0.75 works well with the pitch-robust multi-embedding verification.
# Lower to 0.65 in noisy environments. Raise to 0.82 if getting false accepts.
VANI_SPEAKER_THRESHOLD=0.75

# Dev bypass: set to false to skip speaker verification without touching VANI_SPEAKER_VERIFY.
# Useful when testing other features with friends around and you don't want the gate firing.
# Accepted falsy values: false, 0, no, off   Default: true (gate is active)
VANI_SPEAKER_GATE=true

# Audio ring buffer duration for speaker verification (in 20ms chunks).
# 125 chunks = 2.5 seconds.  More audio = better embedding accuracy.
# Do not change unless you have a reason to.
# (Controlled in wake_listener.py — this is for documentation only.)