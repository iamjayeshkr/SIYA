{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Vani",
  "version": "0.1.0",
  "identifier": "dev.vani.os",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:5500/ui",
    "frontendDist": "http://127.0.0.1:5500/ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vani",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Vani Overlay",
        "url": "http://127.0.0.1:5500/ui?overlay=true",
        "width": 420,
        "height": 100,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Vani"
    },
    "macOSPrivateApi": true,
    "security": {
      "capabilities": [
        {
          "identifier": "default",
          "description": "default",
          "windows": [
            "main",
            "overlay"
          ],
          "permissions": [
            "core:event:allow-listen",
            "core:event:allow-emit",
            "core:event:default",
            "core:window:default",
            "core:window:allow-show",
            "core:window:allow-hide",
            "core:window:allow-set-focus",
            "core:window:allow-set-position",
            "core:window:allow-outer-position",
            "core:window:allow-is-visible",
            "core:app:default",
            "core:webview:default",
            "shell:allow-open",
            "opener:default",
            "notification:default",
            "fs:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png",
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/32x32.png"
    ],
    "category": "Productivity",
    "shortDescription": "Vani \u2014 Your Personal AI",
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}